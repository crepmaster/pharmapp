#!/usr/bin/env sh
# Sprint 5 optimisation #10 (+ Round 2 #5) — fast validate by default:
# typecheck + lint + Jest `--onlyChanged --bail` (runs only tests impacted
# by staged files, exits at the first failure). Keeps the pre-commit loop
# under a couple of seconds for typical edits while still catching breakage.
# Run the FULL suite manually before a push or in CI : `npm run validate`
# (typecheck + lint + all 338 Jest tests, ~15s).
cd functions && npm run validate:fast
