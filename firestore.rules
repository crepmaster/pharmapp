rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {
    function isAdmin() { return request.auth.token.role == 'admin'; }
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return request.auth != null && request.auth.uid == userId; }
    
    // 🔒 SUBSCRIPTION SECURITY FUNCTIONS (UPDATED FOR AFRICAN MARKETS)
    function hasActiveSubscription(userId) {
      let pharmacy = get(/databases/$(db)/documents/pharmacies/$(userId));
      return pharmacy != null && 
             pharmacy.data.hasActiveSubscription == true &&
             (
               // Active subscription
               (pharmacy.data.subscriptionStatus == 'active' &&
                pharmacy.data.subscriptionEndDate > request.time) ||
               // Trial subscription (NEW for African markets)
               (pharmacy.data.subscriptionStatus == 'trial' &&
                (pharmacy.data.subscriptionEndDate == null || 
                 pharmacy.data.subscriptionEndDate > request.time))
             );
    }
    
    function getSubscriptionPlan(userId) {
      let pharmacy = get(/databases/$(db)/documents/pharmacies/$(userId));
      return pharmacy != null ? pharmacy.data.subscriptionPlan : null;
    }
    
    function canCreateInventory(userId, inventoryCount) {
      let plan = getSubscriptionPlan(userId);
      return hasActiveSubscription(userId) && (
        plan == 'basic' && inventoryCount < 100 ||
        plan == 'professional' ||  // Unlimited
        plan == 'enterprise'       // Unlimited
      );
    }
    
    function canCreateProposal(userId) {
      return hasActiveSubscription(userId);
    }

    // Sprint 2D: canonical-first city match for delivery access rules.
    // Compares delivery city against the courier's city using cityCode when both
    // documents carry it; falls back to the legacy city/operatingCity display name
    // for pre-migration documents.  Call sites must call exists() separately.
    function deliveryCityMatchesCourier(deliveryData) {
      let courier = get(/databases/$(db)/documents/couriers/$(request.auth.uid)).data;
      return (deliveryData.cityCode != null && courier.cityCode != null &&
              deliveryData.cityCode == courier.cityCode)
          || (deliveryData.cityCode == null &&
              (deliveryData.city == courier.operatingCity ||
               deliveryData.city == courier.city));
    }

    // Backend-only collections (write restricted to cloud functions)
    match /webhook_logs/{id} { allow write: if false; allow read: if isAdmin(); }
    match /payments/{id}     { allow write: if false; allow read: if isAdmin(); }
    match /ledger/{id} {
      allow write: if false;
      allow read: if isAdmin() ||
        (isAuthenticated() &&
         (isSuperAdmin(request.auth.uid) || isAdminFinancial(request.auth.uid)));
    }
    match /wallets/{userId}  { 
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if false; // Backend-only writes
    }
    match /exchanges/{id}    { allow write: if false; allow read: if isAdmin() || isAuthenticated(); }
    match /idempotency/{id}  { allow write: if false; allow read: if isAdmin(); }

    // 🔒 CRITICAL: Subscription collections (SECURE - BACKEND ONLY)
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() && 
        (get(/databases/$(db)/documents/subscriptions/$(subscriptionId)).data.pharmacyId == request.auth.uid ||
         isSuperAdmin(request.auth.uid));
      allow write: if false; // Only backend functions can write subscription data
    }
    
    match /subscription_payments/{paymentId} {
      allow read: if isAuthenticated() && 
        (get(/databases/$(db)/documents/subscription_payments/$(paymentId)).data.pharmacyId == request.auth.uid ||
         isSuperAdmin(request.auth.uid));
      allow write: if false; // Only payment webhooks can write payment data
    }
    
    match /subscription_config/{configId} {
      allow read: if isAuthenticated(); // Plan configurations are public
      allow write: if isSuperAdmin(request.auth.uid); // Only super admin can modify plans
    }
    
    match /subscription_audit/{auditId} {
      allow read: if isSuperAdmin(request.auth.uid); // Only admin can read audit logs
      allow write: if false; // Only backend functions can write audit logs
    }

    // Admin collection (secure authentication-based access)
    match /admins/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId; // Admin can read own data
      allow read: if isAuthenticated() && isSuperAdmin(request.auth.uid); // Super admin can read all
      allow write: if false; // Only cloud functions or admin SDK should write admin data
    }
    
    // Helper function to check if user is super admin
    function isSuperAdmin(userId) {
      return exists(/databases/$(db)/documents/admins/$(userId)) &&
             get(/databases/$(db)/documents/admins/$(userId)).data.role == 'super_admin';
    }

    // Helper: user exists in admins/ collection and isActive == true.
    // Does NOT check role — use with role/permission helpers below.
    function isActiveAdmin(userId) {
      return exists(/databases/$(db)/documents/admins/$(userId)) &&
             get(/databases/$(db)/documents/admins/$(userId)).data.isActive == true;
    }

    // Helper function to check if user has view_financials permission.
    // Mirrors AdminUser.canViewFinancials (permissions.contains('view_financials') || super_admin).
    // Contract: CONTRACT_ADMIN_MASTER_DATA_AND_TREASURY_V1 §11.1.
    function isAdminFinancial(userId) {
      return isActiveAdmin(userId) &&
             get(/databases/$(db)/documents/admins/$(userId)).data.permissions.hasAny(['view_financials']);
    }

    // V2D: Check if admin's countryScopes includes a specific country code.
    // Uses hasAny([code]) which checks if the array contains the value.
    function adminHasCountryScope(userId, countryCode) {
      return get(/databases/$(db)/documents/admins/$(userId)).data.countryScopes.hasAny([countryCode]);
    }

    // User profiles (base user records)
    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin(request.auth.uid);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isSuperAdmin(request.auth.uid);
    }

    // Mobile app collections
    match /pharmacies/{userId} {
      allow read: if isAuthenticated(); // Other pharmacies can read basic profile info
      allow create: if isOwner(userId) && isValidPharmacyData(request.resource.data);
      allow update: if isOwner(userId) && isValidPharmacyData(request.resource.data);
      allow delete: if isOwner(userId);
    }
    
    // Pharmacy data validation function
    function isValidPharmacyData(data) {
      return data.keys().hasAll(['email', 'pharmacyName', 'phoneNumber', 'address', 'role']) &&
             data.role == 'pharmacy' &&
             data.email is string &&
             data.pharmacyName is string &&
             data.phoneNumber is string &&
             data.address is string &&
             data.isActive is bool &&
             // Subscription fields are optional during creation but if present must be valid
             (!data.keys().hasAny(['hasActiveSubscription']) || data.hasActiveSubscription is bool) &&
             (!data.keys().hasAny(['subscriptionStatus']) || data.subscriptionStatus is string) &&
             // Location data is optional but if present must be valid
             (!data.keys().hasAny(['locationData']) || isValidLocationData(data.locationData));
    }
    
    // Location data validation function
    function isValidLocationData(locationData) {
      return locationData == null || (
        locationData is map &&
        locationData.keys().hasAll(['coordinates']) &&
        isValidCoordinates(locationData.coordinates) &&
        // Address is optional in location data
        (!locationData.keys().hasAny(['address']) || isValidAddress(locationData.address))
      );
    }
    
    // GPS coordinates validation
    function isValidCoordinates(coords) {
      return coords is map &&
             coords.keys().hasAll(['latitude', 'longitude', 'accuracy']) &&
             coords.latitude is number &&
             coords.longitude is number &&
             coords.accuracy is number &&
             coords.latitude >= -90 && coords.latitude <= 90 &&
             coords.longitude >= -180 && coords.longitude <= 180 &&
             coords.accuracy >= 0;
    }
    
    // Address validation function
    function isValidAddress(address) {
      return address is map &&
             address.keys().hasAll(['type']) &&
             address.type is string &&
             address.type in ['formal', 'landmark', 'description'] &&
             address.keys().hasAll(['displayText']) &&
             address.displayText is string;
    }

    match /couriers/{userId} {
      allow read: if isAuthenticated(); // Pharmacies can read courier profiles
      allow create: if isOwner(userId) && isValidCourierData(request.resource.data);
      allow update: if isOwner(userId) && isValidCourierData(request.resource.data);
      allow delete: if isOwner(userId);
    }
    
    // Courier data validation function
    function isValidCourierData(data) {
      return data.keys().hasAll(['email', 'fullName', 'phoneNumber', 'vehicleType', 'licensePlate', 'role']) &&
             data.role == 'courier' &&
             data.email is string &&
             data.fullName is string &&
             data.phoneNumber is string &&
             data.vehicleType is string &&
             data.licensePlate is string &&
             data.isActive is bool &&
             // Optional fields validation
             (!data.keys().hasAny(['hasActiveSubscription']) || data.hasActiveSubscription is bool) &&
             (!data.keys().hasAny(['subscriptionStatus']) || data.subscriptionStatus is string) &&
             (!data.keys().hasAny(['operatingCity']) || data.operatingCity is string);
    }
    
    // NOTE: subscriptions and subscription_payments rules are defined above (lines 54-76) as backend-only.
    // Do NOT add duplicate rules here.

    match /pharmacy_inventory/{id} {
      // V2 Inventory Visibility: owner reads all own items;
      // other users read only Published items (availableForExchange == true).
      // Super admin can read all.
      allow read: if isAuthenticated() &&
        (resource.data.pharmacyId == request.auth.uid ||
         resource.data.availabilitySettings.availableForExchange == true ||
         isSuperAdmin(request.auth.uid));
      // 🔒 CRITICAL: Inventory creation requires active subscription
      allow create: if isAuthenticated() &&
                   request.resource.data.pharmacyId == request.auth.uid &&
                   hasActiveSubscription(request.auth.uid);
      // 🔒 CRITICAL: Only subscription holders can update/delete inventory
      allow update, delete: if isAuthenticated() &&
                           resource.data.pharmacyId == request.auth.uid &&
                           hasActiveSubscription(request.auth.uid);
    }

    match /exchange_proposals/{id} {
      allow read: if isAuthenticated(); // All authenticated users can read proposals
      // 🔒 CRITICAL: Creating proposals requires active subscription
      allow create: if isAuthenticated() && hasActiveSubscription(request.auth.uid);
      // 🔒 CRITICAL: Updating proposals requires active subscription for both parties
      allow update: if isAuthenticated() && (
        (resource.data.fromPharmacyId == request.auth.uid && hasActiveSubscription(request.auth.uid)) || 
        (resource.data.toPharmacyId == request.auth.uid && hasActiveSubscription(request.auth.uid))
      );
      // 🔒 CRITICAL: Deleting proposals requires active subscription
      allow delete: if isAuthenticated() && 
                   resource.data.fromPharmacyId == request.auth.uid &&
                   hasActiveSubscription(request.auth.uid);
    }

    match /deliveries/{id} {
      allow read: if isAuthenticated() && (
        // Only couriers can browse pending deliveries, and only in their operating city
        (resource.data.status == 'pending' &&
         exists(/databases/$(db)/documents/couriers/$(request.auth.uid)) &&
         deliveryCityMatchesCourier(resource.data)) ||
        resource.data.courierId == request.auth.uid ||           // Courier can read assigned deliveries
        resource.data.fromPharmacyId == request.auth.uid ||      // Source pharmacy can read
        resource.data.toPharmacyId == request.auth.uid ||        // Destination pharmacy can read
        isSuperAdmin(request.auth.uid)                           // Super admin can read all
      );
      allow create: if isAuthenticated() && isSuperAdmin(request.auth.uid); // Only admins create deliveries
      // Update rules:
      // 1. Courier accepting: must be pending, unassigned, courier in same city, must set courierId to self
      // 2. Assigned courier: can update status/location on their own delivery
      // 3. Admin: can update anything
      // Pharmacies CANNOT update deliveries (status changes go through Cloud Functions)
      allow update: if isAuthenticated() && (
        // Accept: courier in same city, delivery pending+unassigned, must assign to self
        // Field whitelist prevents altering city, courierFee, pharmacyIds, items, etc.
        (resource.data.status == 'pending' &&
         resource.data.courierId == null &&
         exists(/databases/$(db)/documents/couriers/$(request.auth.uid)) &&
         deliveryCityMatchesCourier(resource.data) &&
         request.resource.data.courierId == request.auth.uid &&
         request.resource.data.status == 'accepted' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(
           ['courierId', 'courierName', 'status', 'assignedAt', 'acceptedAt', 'updatedAt']
         )) ||
        // Assigned courier can update their own delivery (field-restricted)
        // Prevents modification of financial fields (courierFee, totalPrice, currency, etc.)
        (resource.data.courierId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(
           ['status', 'updatedAt', 'pickedUpAt', 'deliveredAt', 'failureReason',
            'notes', 'proofImages', 'hasIssue', 'lastIssueReportedAt']
         )) ||
        // Admin override
        isSuperAdmin(request.auth.uid)
      );
    }

    // Delivery issue reporting
    match /delivery_issues/{id} {
      allow read: if isAuthenticated() && (
        resource.data.courierId == request.auth.uid ||           // Courier can read own issues
        isSuperAdmin(request.auth.uid)                           // Super admin can read all
      );
      allow create: if isAuthenticated();                        // Any authenticated user can report issues
      allow update: if isAuthenticated() && isSuperAdmin(request.auth.uid); // Only admin can resolve issues
    }

    match /medicines/{id} {
      allow read: if isAuthenticated();
      // Only pharmacy-role users can create/update medicines
      allow create, update: if isAuthenticated() &&
        exists(/databases/$(db)/documents/pharmacies/$(request.auth.uid));
    }

    // Dynamic subscription plans (runtime-readable, super_admin writable)
    // Note: subscription_config rule (L68) covers the legacy collection name;
    // this rule covers the actual collection used by admin_panel code.
    match /dynamic_subscription_plans/{planId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isSuperAdmin(request.auth.uid);
    }

    // System configuration V1 — runtime source of truth for countries,
    // cities, currencies, mobile money providers, revenue policies.
    // Contract: CONTRACT_ADMIN_MASTER_DATA_AND_TREASURY_V1 §11.
    // Read is public: the registration flow reads system_config/main before
    // the user has authenticated (Sprint 2A decision).
    match /system_config/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isSuperAdmin(request.auth.uid);
    }

    // Platform treasuries — accumulate subscription and other platform revenue.
    // Contract: CONTRACT_ADMIN_MASTER_DATA_AND_TREASURY_V1 §6.2 and §11.
    // Document ID convention: {countryCode}_{currencyCode} (e.g. "CM_XAF").
    // Read: super_admin global; finance admins scoped by countryCode (V2D).
    // Write: backend-only via Cloud Functions.
    match /platform_treasuries/{treasuryId} {
      allow read: if isAuthenticated() &&
        (isSuperAdmin(request.auth.uid) ||
         (isAdminFinancial(request.auth.uid) &&
          adminHasCountryScope(request.auth.uid, resource.data.countryCode)));
      allow write: if false; // Backend-only — Cloud Functions use Admin SDK
    }

    // Admin payout accounts — mobile money accounts used by admins to receive payouts.
    // Contract: CONTRACT_ADMIN_MASTER_DATA_AND_TREASURY_V1 §6.3.
    // Read: owning admin (own accounts only) or super_admin.
    // Create/Update: owning admin only (immutable fields enforced by service layer).
    //   V2D: non-super_admin must have countryScope for the account's countryCode.
    // Delete: super_admin only.
    match /admin_payout_accounts/{accountId} {
      allow read: if isAuthenticated() &&
        (resource.data.adminUserId == request.auth.uid ||
         isSuperAdmin(request.auth.uid));
      // Only active admins can create their own payout accounts.
      // V2D: non-super_admin must have countryScope for the account's countryCode.
      allow create: if isAuthenticated() &&
        isActiveAdmin(request.auth.uid) &&
        request.resource.data.adminUserId == request.auth.uid &&
        request.resource.data.verificationStatus == 'unverified' &&
        request.resource.data.accountType == 'mobile_money' &&
        (isSuperAdmin(request.auth.uid) ||
         adminHasCountryScope(request.auth.uid, request.resource.data.countryCode));
      // Only the owning active admin can update; immutable fields are protected.
      // V2D: non-super_admin must have countryScope for the account's countryCode.
      allow update: if isAuthenticated() &&
        isActiveAdmin(request.auth.uid) &&
        resource.data.adminUserId == request.auth.uid &&
        (isSuperAdmin(request.auth.uid) ||
         adminHasCountryScope(request.auth.uid, resource.data.countryCode)) &&
        // Immutable fields must not change.
        request.resource.data.adminUserId == resource.data.adminUserId &&
        request.resource.data.countryCode == resource.data.countryCode &&
        request.resource.data.currencyCode == resource.data.currencyCode &&
        request.resource.data.providerId == resource.data.providerId &&
        request.resource.data.accountType == resource.data.accountType &&
        request.resource.data.createdAt == resource.data.createdAt &&
        // verificationStatus cannot be promoted client-side (Lot 4 backend callable).
        request.resource.data.verificationStatus == resource.data.verificationStatus;
      allow delete: if isAuthenticated() && isSuperAdmin(request.auth.uid);
    }

    // Platform payout requests — tracks payout requests from treasury to admin accounts.
    // Contract: CONTRACT_ADMIN_MASTER_DATA_AND_TREASURY_V1 §6 (Sprint 4B).
    // Document ID: auto-generated.
    // Read: owning admin (own requests) or super_admin global or
    //        finance admin scoped by countryCode (V2D).
    // Write: backend-only via Cloud Functions (requestPlatformPayout, resolvePlatformPayout).
    match /platform_payout_requests/{requestId} {
      allow read: if isAuthenticated() &&
        (resource.data.adminUserId == request.auth.uid ||
         isSuperAdmin(request.auth.uid) ||
         (isAdminFinancial(request.auth.uid) &&
          adminHasCountryScope(request.auth.uid, resource.data.countryCode)));
      allow write: if false; // Backend-only — Cloud Functions use Admin SDK
    }

    // Medicine requests — inter-pharmacy sourcing requests (Sprint 2A).
    // Read: owner always; open requests readable by any authenticated user
    //        (city filtering done client-side for cost efficiency).
    // Write: backend-only via callables (createMedicineRequest, cancelMedicineRequest,
    //        acceptMedicineRequestOffer). Client writes denied to prevent forged
    //        requests, status manipulation, or cross-city bypass.
    match /medicine_requests/{requestId} {
      allow read: if isAuthenticated() &&
        (resource.data.requesterPharmacyId == request.auth.uid ||
         resource.data.status == 'open' ||
         isSuperAdmin(request.auth.uid));
      allow write: if false; // Backend-only — Cloud Functions use Admin SDK
    }

    // Medicine request offers — responses to sourcing requests (Sprint 2A).
    // Read: requester + seller only.
    // Write: backend-only via callables (submitMedicineRequestOffer,
    //        withdrawMedicineRequestOffer, acceptMedicineRequestOffer).
    //        Client writes denied to prevent forged offers or status manipulation.
    match /medicine_request_offers/{offerId} {
      allow read: if isAuthenticated() &&
        (resource.data.requesterPharmacyId == request.auth.uid ||
         resource.data.sellerPharmacyId == request.auth.uid ||
         isSuperAdmin(request.auth.uid));
      allow write: if false; // Backend-only — Cloud Functions use Admin SDK
    }

    // Backups of system_config before migrations — super_admin only.
    match /system_config_backups/{docId} {
      allow read, write: if isAuthenticated() && isSuperAdmin(request.auth.uid);
    }

    // ========== DEFAULT DENY ALL ==========
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
